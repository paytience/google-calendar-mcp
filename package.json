{
  "name": "@paytience/google-calendar-mcp",
  "version": "1.0.0",
  "description": "MCP server for Google Calendar",
  "main": "dist/index.js",
  "bin": {
    "google-calendar-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit && node build.mjs",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run --exclude src/__tests__/e2e.test.ts",
    "test:e2e": "npm run build && vitest run src/__tests__/e2e.test.ts",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "google-calendar",
    "calendar",
    "scheduling",
    "google-api",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf",
    "ai-assistant",
    "google-workspace"
  ],
  "homepage": "https://mcpcalendar.com",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/paytience/google-calendar-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "googleapis": "^144.0.0",
    "open": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
