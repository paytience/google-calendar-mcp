{
  "name": "@paytience/outlook-mcp",
  "version": "1.1.0",
  "description": "MCP server for Microsoft Outlook email and calendar",
  "main": "dist/index.js",
  "bin": {
    "outlook-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "outlook",
    "email",
    "calendar",
    "contacts",
    "microsoft-graph",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf",
    "ai-assistant",
    "outlook-api",
    "microsoft-365"
  ],
  "homepage": "https://mcpoutlook.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paytience/outlook-mcp"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "isomorphic-fetch": "^3.0.0",
    "open": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
